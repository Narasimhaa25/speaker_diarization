<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Module 2 — Speaker Diarization & Staff ID</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
         background: #0f1117; color: #e2e8f0; min-height: 100vh; }

  .header { background: #1a1d2e; border-bottom: 1px solid #2d3748; padding: 20px 32px;
            display: flex; align-items: center; gap: 16px; }
  .header h1 { font-size: 1.25rem; font-weight: 600; color: #fff; }
  .header .badge { background: #4f8ef7; color: #fff; padding: 3px 10px;
                   border-radius: 12px; font-size: 0.75rem; font-weight: 600; }
  .header .subtitle { color: #718096; font-size: 0.85rem; margin-top: 2px; }

  .main { max-width: 1100px; margin: 0 auto; padding: 32px 24px; }

  /* Upload card */
  .card { background: #1a1d2e; border: 1px solid #2d3748; border-radius: 12px;
          padding: 24px; margin-bottom: 24px; }
  .card h2 { font-size: 1rem; font-weight: 600; color: #a0aec0;
             text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 16px; }

  .upload-zone { border: 2px dashed #2d3748; border-radius: 8px; padding: 40px;
                 text-align: center; cursor: pointer; transition: all 0.2s;
                 background: #0f1117; }
  .upload-zone:hover, .upload-zone.drag { border-color: #4f8ef7; background: #131728; }
  .upload-zone .icon { font-size: 2.5rem; margin-bottom: 12px; }
  .upload-zone p { color: #718096; font-size: 0.9rem; }
  .upload-zone .filename { color: #4f8ef7; font-weight: 600; margin-top: 8px; }

  .controls { display: flex; gap: 16px; align-items: flex-end; margin-top: 16px;
              flex-wrap: wrap; }
  .control-group { display: flex; flex-direction: column; gap: 6px; }
  .control-group label { font-size: 0.8rem; color: #718096; }
  .control-group input[type=range] { width: 200px; accent-color: #4f8ef7; }
  .threshold-val { color: #4f8ef7; font-weight: 600; font-size: 0.85rem; }

  .btn { background: #4f8ef7; color: #fff; border: none; padding: 10px 24px;
         border-radius: 8px; cursor: pointer; font-size: 0.95rem; font-weight: 600;
         transition: background 0.2s; }
  .btn:hover { background: #3b7de8; }
  .btn:disabled { background: #2d3748; color: #718096; cursor: not-allowed; }

  /* Staff DB status */
  .staff-chips { display: flex; gap: 8px; flex-wrap: wrap; }
  .chip { background: #1e2a3a; border: 1px solid #2d3748; border-radius: 20px;
          padding: 4px 12px; font-size: 0.8rem; color: #68d391; }
  .chip-empty { color: #718096; font-size: 0.85rem; font-style: italic; }

  /* Progress */
  .progress { display: none; margin: 16px 0; }
  .progress-bar { background: #2d3748; border-radius: 4px; height: 6px; overflow: hidden; }
  .progress-fill { background: linear-gradient(90deg, #4f8ef7, #68d391);
                   height: 100%; width: 0%; transition: width 0.3s;
                   animation: pulse 1.5s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.7} }
  .progress-text { color: #718096; font-size: 0.85rem; margin-top: 8px; }

  /* Results */
  #results { display: none; }

  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
                gap: 16px; margin-bottom: 24px; }
  .stat { background: #1a1d2e; border: 1px solid #2d3748; border-radius: 10px;
          padding: 16px 20px; }
  .stat .val { font-size: 1.8rem; font-weight: 700; color: #fff; }
  .stat .lbl { font-size: 0.78rem; color: #718096; margin-top: 2px;
               text-transform: uppercase; letter-spacing: 0.04em; }
  .stat.green .val { color: #68d391; }
  .stat.blue  .val { color: #63b3ed; }
  .stat.amber .val { color: #f6ad55; }

  /* Timeline */
  .timeline-wrap { overflow-x: auto; padding: 8px 0; }
  .timeline { position: relative; height: 56px; background: #0f1117;
              border-radius: 6px; min-width: 600px; }
  .timeline-seg { position: absolute; top: 8px; height: 40px; border-radius: 4px;
                  display: flex; align-items: center; justify-content: center;
                  font-size: 0.7rem; font-weight: 600; overflow: hidden;
                  cursor: pointer; transition: opacity 0.2s; }
  .timeline-seg:hover { opacity: 0.85; }
  .timeline-seg .seg-label { white-space: nowrap; overflow: hidden;
                              text-overflow: ellipsis; padding: 0 4px; color: #fff; }
  .timeline-ticks { display: flex; justify-content: space-between;
                    padding: 4px 0 0; min-width: 600px; }
  .timeline-ticks span { font-size: 0.7rem; color: #4a5568; }

  /* Legend */
  .legend { display: flex; gap: 20px; flex-wrap: wrap; margin-top: 12px; }
  .legend-item { display: flex; align-items: center; gap: 6px; font-size: 0.8rem; color: #a0aec0; }
  .legend-dot { width: 10px; height: 10px; border-radius: 50%; }

  /* Table */
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  th { text-align: left; padding: 10px 12px; color: #718096; font-weight: 500;
       text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.04em;
       border-bottom: 1px solid #2d3748; }
  td { padding: 10px 12px; border-bottom: 1px solid #1e2535; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: #1e2535; }

  .role-staff    { background: #1a3a2a; color: #68d391; padding: 2px 8px;
                   border-radius: 4px; font-weight: 600; font-size: 0.78rem; }
  .role-customer { background: #1a2a3a; color: #63b3ed; padding: 2px 8px;
                   border-radius: 4px; font-weight: 600; font-size: 0.78rem; }
  .role-unknown  { background: #2a2a1a; color: #f6ad55; padding: 2px 8px;
                   border-radius: 4px; font-weight: 600; font-size: 0.78rem; }

  .score-bar { display: flex; align-items: center; gap: 8px; }
  .score-fill { height: 6px; border-radius: 3px; background: #4f8ef7; min-width: 2px; }

  /* Speaking time bars */
  .speaker-bars { display: flex; flex-direction: column; gap: 10px; }
  .speaker-row { display: flex; align-items: center; gap: 12px; }
  .speaker-name { width: 80px; font-size: 0.85rem; color: #a0aec0; text-align: right; }
  .speaker-bar-bg { flex: 1; background: #2d3748; border-radius: 4px; height: 18px; overflow: hidden; }
  .speaker-bar-fill { height: 100%; border-radius: 4px; display: flex;
                      align-items: center; padding-left: 8px;
                      font-size: 0.72rem; font-weight: 600; color: #fff;
                      transition: width 0.6s ease; }

  /* Pie chart (CSS) */
  .pie-wrap { display: flex; align-items: center; gap: 24px; }
  .pie { width: 100px; height: 100px; border-radius: 50%; }
  .pie-legend { display: flex; flex-direction: column; gap: 8px; }
  .pie-legend-row { display: flex; align-items: center; gap: 8px; font-size: 0.85rem; }
  .pie-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }

  .error-box { background: #2a1a1a; border: 1px solid #c53030; border-radius: 8px;
               padding: 16px; color: #fc8181; font-size: 0.9rem; margin-top: 16px; }

  /* ── Real-time mic section ──────────────────────────────────────────────── */
  .mic-zone { border: 2px dashed #2d3748; border-radius: 8px; padding: 32px 24px;
              text-align: center; background: #0f1117; position: relative; }
  .mic-zone.recording { border-color: #fc8181; animation: mic-pulse 1.2s infinite; }
  @keyframes mic-pulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(252,129,129,0); border-color: #fc8181; }
    50%      { box-shadow: 0 0 0 8px rgba(252,129,129,0.15); border-color: #feb2b2; }
  }
  .mic-btn { width: 72px; height: 72px; border-radius: 50%; border: none;
             font-size: 2rem; cursor: pointer; transition: all 0.2s;
             display: inline-flex; align-items: center; justify-content: center;
             margin-bottom: 12px; }
  .mic-btn.idle      { background: #2d3748; color: #a0aec0; }
  .mic-btn.idle:hover{ background: #4a5568; }
  .mic-btn.active    { background: #c53030; color: #fff;
                       box-shadow: 0 0 0 6px rgba(197,48,48,0.25); }
  .mic-btn.processing{ background: #2d5986; color: #63b3ed; cursor: not-allowed; }
  .mic-status      { font-size: 0.88rem; color: #718096; }
  .mic-status.live { color: #fc8181; font-weight: 600; }
  .mic-status.ok   { color: #68d391; font-weight: 600; }
  .live-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%;
              background: #fc8181; margin-right: 6px; animation: blink 1s infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }
  .waveform-canvas { width: 100%; height: 48px; margin-top: 16px; border-radius: 6px;
                     background: #0f1117; display: none; }
  .realtime-results { margin-top: 20px; display: none; }
  .rt-badge { display: inline-block; background: #1a3a2a; border: 1px solid #68d391;
              color: #68d391; border-radius: 6px; padding: 2px 10px;
              font-size: 0.75rem; font-weight: 700; margin-bottom: 12px; }
  .rec-timer { font-size: 0.82rem; color: #4a5568; margin-top: 6px; display: none; }
</style>
</head>
<body>

<div class="header">
  <div>
    <div style="display:flex;align-items:center;gap:10px">
      <h1>Speaker Diarization &amp; Staff Voice ID</h1>
      <span class="badge">Module 2</span>
    </div>
    <div class="subtitle">Who spoke when · Staff or customer · Powered by pyannote + ECAPA-TDNN</div>
  </div>
</div>

<div class="main">

  <!-- Upload card -->
  <div class="card">
    <h2>Upload Audio</h2>
    <div class="upload-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
      <div class="icon">🎙</div>
      <p>Drag &amp; drop an audio file here, or click to browse</p>
      <p style="margin-top:6px;font-size:0.78rem">WAV · MP3 · M4A · FLAC · OGG</p>
      <div class="filename" id="fileLabel"></div>
    </div>
    <input type="file" id="fileInput" accept=".wav,.mp3,.m4a,.flac,.ogg" style="display:none">

    <div class="controls">
      <div class="control-group">
        <label>Staff similarity threshold: <span class="threshold-val" id="threshVal">0.82</span></label>
        <input type="range" id="threshold" min="0.60" max="0.95" step="0.01" value="0.82"
               oninput="document.getElementById('threshVal').textContent=parseFloat(this.value).toFixed(2)">
        <span style="font-size:0.72rem;color:#4a5568">Lower = more staff matches · Higher = stricter</span>
      </div>
      <div class="control-group">
        <label>Max duration: <span class="threshold-val" id="durVal">120s</span></label>
        <input type="range" id="maxDur" min="30" max="825" step="30" value="120"
               oninput="document.getElementById('durVal').textContent=this.value+'s'">
        <span style="font-size:0.72rem;color:#4a5568">Longer = slower · 120s ≈ 2 min processing</span>
      </div>
      <button class="btn" id="analyseBtn" onclick="runAnalysis()" disabled>Analyse</button>
    </div>

    <div class="progress" id="progress">
      <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
      <div class="progress-text" id="progressText">Loading models…</div>
    </div>
    <div class="error-box" id="errorBox" style="display:none"></div>
  </div>

  <!-- ── Real-Time Microphone ─────────────────────────────────────────── -->
  <div class="card">
    <h2>Real-Time Voice Input</h2>
    <p style="color:#718096;font-size:0.82rem;margin-bottom:16px">
      Speak into your microphone — audio is captured, diarized, and identified automatically
      when you stop recording.
    </p>

    <div class="mic-zone" id="micZone">
      <button class="mic-btn idle" id="micBtn" onclick="toggleMic()" title="Start / stop recording">
        🎤
      </button>
      <div>
        <div class="mic-status" id="micStatus">Click the microphone to start recording</div>
        <div class="rec-timer" id="recTimer">0:00</div>
      </div>
      <canvas class="waveform-canvas" id="waveformCanvas"></canvas>
    </div>

    <!-- Mic controls (same threshold / duration sliders reused from upload section) -->
    <div class="controls" style="margin-top:14px">
      <button class="btn" id="micAnalyseBtn" style="display:none" onclick="submitMicRecording()">
        Analyse Recording
      </button>
      <button class="btn" id="micClearBtn"
              style="display:none;background:#2d3748;color:#a0aec0"
              onclick="clearMicRecording()">
        Discard
      </button>
    </div>

    <div class="progress" id="micProgress">
      <div class="progress-bar"><div class="progress-fill" id="micProgressFill"></div></div>
      <div class="progress-text" id="micProgressText">Processing…</div>
    </div>
    <div class="error-box" id="micErrorBox" style="display:none"></div>

    <!-- Inline results for mic (same renderer, different container) -->
    <div class="realtime-results" id="micResults">
      <div class="rt-badge">🎙 REAL-TIME RESULT</div>
      <div class="stats-grid" id="micStatsGrid"></div>
      <div class="card" style="margin-top:16px">
        <h2>Speaker Timeline</h2>
        <div class="timeline-wrap">
          <div class="timeline" id="micTimeline"></div>
          <div class="timeline-ticks" id="micTimelineTicks"></div>
        </div>
        <div class="legend" id="micLegend"></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:16px">
        <div class="card">
          <h2>Speaking Time</h2>
          <div class="speaker-bars" id="micSpeakerBars"></div>
        </div>
        <div class="card">
          <h2>Staff vs Customer</h2>
          <div class="pie-wrap">
            <canvas id="micPieChart" width="100" height="100"></canvas>
            <div class="pie-legend" id="micPieLegend"></div>
          </div>
        </div>
      </div>
      <div class="card" style="margin-top:16px">
        <h2>Segment Details</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Start</th><th>End</th><th>Duration</th>
                <th>Speaker</th><th>Role</th><th>Name</th><th>Score</th>
              </tr>
            </thead>
            <tbody id="micSegTable"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- AMI Sample Files -->
  {% if ami_files %}
  <div class="card">
    <h2>Sample Files — AMI Corpus</h2>
    <p style="color:#718096;font-size:0.82rem;margin-bottom:16px">
      Click any file to analyse it directly — no upload needed.
    </p>
    {% set meetings = ami_files | map(attribute='meeting') | unique | list %}
    {% for meeting in meetings %}
    <div style="margin-bottom:16px">
      <div style="font-size:0.8rem;color:#4f8ef7;font-weight:600;
                  text-transform:uppercase;letter-spacing:0.05em;margin-bottom:8px">
        {{ meeting }}
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:8px">
        {% for f in ami_files if f.meeting == meeting %}
        <button class="ami-btn" data-path="{{ f.path }}"
                onclick="loadSample(this)"
                style="background:#1e2535;border:1px solid #2d3748;color:#e2e8f0;
                       padding:8px 14px;border-radius:8px;cursor:pointer;
                       font-size:0.82rem;transition:all 0.2s;text-align:left">
          <div style="font-weight:600;color:{% if 'Mix' in f.kind %}#68d391{% else %}#63b3ed{% endif %}">
            {{ f.kind }}
          </div>
          <div style="font-size:0.72rem;color:#718096;margin-top:2px">{{ f.size_mb }} MB</div>
        </button>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <!-- Staff DB -->
  <div class="card">
    <h2>Enrolled Staff</h2>
    <div class="staff-chips">
      {% if staff_list %}
        {% for s in staff_list %}
          <span class="chip">{{ s.name }} ({{ s.role }})</span>
        {% endfor %}
      {% else %}
        <span class="chip-empty">No staff enrolled — run enrollment first</span>
      {% endif %}
    </div>
  </div>

  <!-- Results -->
  <div id="results">

    <!-- Stats -->
    <div class="stats-grid" id="statsGrid"></div>

    <!-- Timeline -->
    <div class="card">
      <h2>Speaker Timeline</h2>
      <div class="timeline-wrap">
        <div class="timeline" id="timeline"></div>
        <div class="timeline-ticks" id="timelineTicks"></div>
      </div>
      <div class="legend" id="legend"></div>
    </div>

    <!-- Speaking time + pie -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px">
      <div class="card">
        <h2>Speaking Time</h2>
        <div class="speaker-bars" id="speakerBars"></div>
      </div>
      <div class="card">
        <h2>Staff vs Customer</h2>
        <div class="pie-wrap">
          <canvas id="pieChart" width="100" height="100"></canvas>
          <div class="pie-legend" id="pieLegend"></div>
        </div>
      </div>
    </div>

    <!-- Table -->
    <div class="card">
      <h2>Segment Details</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Start</th><th>End</th><th>Duration</th>
              <th>Speaker</th><th>Role</th><th>Name</th>
              <th>Score</th>
            </tr>
          </thead>
          <tbody id="segTable"></tbody>
        </table>
      </div>
    </div>

  </div><!-- /results -->

</div><!-- /main -->

<script>
const fileInput = document.getElementById('fileInput');
const dropZone  = document.getElementById('dropZone');
const analyseBtn= document.getElementById('analyseBtn');
const progress  = document.getElementById('progress');
const progressFill = document.getElementById('progressFill');
const progressText = document.getElementById('progressText');
const errorBox  = document.getElementById('errorBox');

let selectedFile = null;

// ── File selection ────────────────────────────────────────────────────────────
fileInput.addEventListener('change', e => selectFile(e.target.files[0]));

dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag'));
dropZone.addEventListener('drop', e => {
  e.preventDefault(); dropZone.classList.remove('drag');
  if (e.dataTransfer.files[0]) selectFile(e.dataTransfer.files[0]);
});

function selectFile(f) {
  selectedFile = f;
  document.getElementById('fileLabel').textContent = f.name;
  analyseBtn.disabled = false;
  errorBox.style.display = 'none';
}

// ── Analysis ──────────────────────────────────────────────────────────────────
async function runAnalysis() {
  if (!selectedFile) return;

  analyseBtn.disabled = true;
  document.getElementById('results').style.display = 'none';
  errorBox.style.display = 'none';
  progress.style.display = 'block';

  const steps = [
    [10, 'Loading audio…'],
    [25, 'Estimating speaker count…'],
    [40, 'Running neural diarization (pyannote)…'],
    [70, 'Computing voice embeddings (ECAPA-TDNN)…'],
    [85, 'Matching against staff database…'],
    [95, 'Building results…'],
  ];
  let si = 0;
  const ticker = setInterval(() => {
    if (si < steps.length) {
      progressFill.style.width = steps[si][0] + '%';
      progressText.textContent = steps[si][1];
      si++;
    }
  }, 1800);

  const fd = new FormData();
  fd.append('audio', selectedFile);
  fd.append('threshold', document.getElementById('threshold').value);
  fd.append('max_duration', document.getElementById('maxDur').value);

  try {
    const resp = await fetch('/analyse', { method: 'POST', body: fd });
    clearInterval(ticker);
    progressFill.style.width = '100%';
    progressText.textContent = 'Done!';

    const data = await resp.json();
    setTimeout(() => { progress.style.display = 'none'; }, 500);

    if (data.error) {
      showError(data.error);
    } else {
      renderResults(data);
    }
  } catch (err) {
    clearInterval(ticker);
    progress.style.display = 'none';
    showError('Request failed: ' + err.message);
  }
  analyseBtn.disabled = false;
}

// ── Load AMI sample file ──────────────────────────────────────────────────────
async function loadSample(btn) {
  const path = btn.dataset.path;

  // Highlight selected button
  document.querySelectorAll('.ami-btn').forEach(b => b.style.borderColor = '#2d3748');
  btn.style.borderColor = '#4f8ef7';

  analyseBtn.disabled = true;
  document.getElementById('results').style.display = 'none';
  errorBox.style.display = 'none';
  progress.style.display = 'block';
  document.getElementById('fileLabel').textContent = btn.querySelector('div').textContent.trim();

  const steps = [
    [10, 'Loading audio…'],
    [25, 'Estimating speaker count…'],
    [40, 'Running neural diarization (pyannote)…'],
    [70, 'Computing voice embeddings (ECAPA-TDNN)…'],
    [85, 'Matching against staff database…'],
    [95, 'Building results…'],
  ];
  let si = 0;
  const ticker = setInterval(() => {
    if (si < steps.length) {
      progressFill.style.width = steps[si][0] + '%';
      progressText.textContent = steps[si][1];
      si++;
    }
  }, 1800);

  try {
    const resp = await fetch('/analyse_sample', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        path:         path,
        threshold:    parseFloat(document.getElementById('threshold').value),
        max_duration: parseFloat(document.getElementById('maxDur').value),
      }),
    });
    clearInterval(ticker);
    progressFill.style.width = '100%';
    progressText.textContent = 'Done!';
    setTimeout(() => { progress.style.display = 'none'; }, 500);

    const data = await resp.json();
    if (data.error) showError(data.error);
    else renderResults(data);
  } catch (err) {
    clearInterval(ticker);
    progress.style.display = 'none';
    showError('Request failed: ' + err.message);
  }
  analyseBtn.disabled = !selectedFile;
}

function showError(msg) {
  errorBox.textContent = '✗ ' + msg;
  errorBox.style.display = 'block';
}

// ── Render results ────────────────────────────────────────────────────────────
function renderResults(d) {
  document.getElementById('results').style.display = 'block';

  // Stats
  const total = d.staff_count + d.customer_count;
  const staffPct = total > 0 ? Math.round(d.staff_count / total * 100) : 0;
  const trimNote = d.total_duration > d.duration
    ? ` <span style="font-size:0.7rem;color:#718096">of ${fmt(d.total_duration)}</span>` : '';
  document.getElementById('statsGrid').innerHTML = `
    <div class="stat"><div class="val">${fmt(d.duration)}${trimNote}</div><div class="lbl">Processed</div></div>
    <div class="stat blue"><div class="val">${d.segments.length}</div><div class="lbl">Segments</div></div>
    <div class="stat green"><div class="val">${d.staff_count}</div><div class="lbl">Staff turns</div></div>
    <div class="stat amber"><div class="val">${d.customer_count}</div><div class="lbl">Customer turns</div></div>
    <div class="stat"><div class="val">${d.est_speakers}</div><div class="lbl">Speakers est.</div></div>
    <div class="stat"><div class="val">${d.rtf}x</div><div class="lbl">RTF</div></div>
    <div class="stat"><div class="val">${d.elapsed}s</div><div class="lbl">Processing time</div></div>
    <div class="stat"><div class="val">${d.threshold}</div><div class="lbl">Threshold</div></div>
  `;

  // Timeline
  renderTimeline(d);

  // Speaking time bars
  const maxT = Math.max(...Object.values(d.speaker_totals), 1);
  document.getElementById('speakerBars').innerHTML =
    Object.entries(d.speaker_totals).sort((a,b) => b[1]-a[1]).map(([spk, t]) => `
      <div class="speaker-row">
        <div class="speaker-name">${spk}</div>
        <div class="speaker-bar-bg">
          <div class="speaker-bar-fill"
               style="width:${t/maxT*100}%;background:${d.speaker_colour[spk] || '#4f8ef7'}">
            ${t.toFixed(1)}s
          </div>
        </div>
      </div>`).join('');

  // Pie chart
  renderPie(d);

  // Table
  document.getElementById('segTable').innerHTML = d.segments.map(s => `
    <tr>
      <td>${fmt(s.start)}</td>
      <td>${fmt(s.end)}</td>
      <td>${s.duration.toFixed(1)}s</td>
      <td><span style="color:${d.speaker_colour[s.speaker_id]||'#fff'}">${s.speaker_id}</span></td>
      <td><span class="role-${s.role}">${s.role.toUpperCase()}</span></td>
      <td>${s.name || '<span style="color:#4a5568">—</span>'}</td>
      <td>
        <div class="score-bar">
          <div class="score-fill" style="width:${Math.round(s.score*80)}px;
               background:${s.score >= d.threshold ? '#68d391' : '#4f8ef7'}"></div>
          <span style="font-size:0.8rem;color:#a0aec0">${s.score.toFixed(3)}</span>
        </div>
      </td>
    </tr>`).join('');

  document.getElementById('results').scrollIntoView({ behavior: 'smooth' });
}

function renderTimeline(d) {
  const dur = d.duration;
  const tl  = document.getElementById('timeline');
  tl.innerHTML = '';

  d.segments.forEach(s => {
    const left  = (s.start / dur * 100).toFixed(2);
    const width = Math.max((s.duration / dur * 100), 0.3).toFixed(2);
    const col   = d.speaker_colour[s.speaker_id] || '#4f8ef7';
    const alpha = s.role === 'staff' ? 'ff' : '99';
    const div   = document.createElement('div');
    div.className = 'timeline-seg';
    div.style.cssText = `left:${left}%;width:${width}%;background:${col}${alpha}`;
    div.title = `${s.speaker_id} · ${s.role}${s.name ? ' · ' + s.name : ''} · ${fmt(s.start)}–${fmt(s.end)}`;
    if (parseFloat(width) > 3) {
      div.innerHTML = `<span class="seg-label">${s.name || s.speaker_id}</span>`;
    }
    tl.appendChild(div);
  });

  // Ticks
  const ticks = document.getElementById('timelineTicks');
  ticks.innerHTML = '';
  const nTicks = 6;
  for (let i = 0; i <= nTicks; i++) {
    const t = dur * i / nTicks;
    const sp = document.createElement('span');
    sp.textContent = fmt(t);
    ticks.appendChild(sp);
  }

  // Legend
  document.getElementById('legend').innerHTML =
    Object.entries(d.speaker_colour).map(([spk, col]) => `
      <div class="legend-item">
        <div class="legend-dot" style="background:${col}"></div>
        ${spk}
      </div>`).join('') +
    `<div class="legend-item"><div class="legend-dot" style="background:#68d391;opacity:0.6"></div>Full opacity = STAFF</div>
     <div class="legend-item"><div class="legend-dot" style="background:#4f8ef7;opacity:0.4"></div>Faded = CUSTOMER</div>`;
}

function renderPie(d) {
  const canvas = document.getElementById('pieChart');
  const ctx    = canvas.getContext('2d');
  const total  = (d.staff_count + d.customer_count) || 1;
  const staffAngle = (d.staff_count / total) * 2 * Math.PI;

  ctx.clearRect(0, 0, 100, 100);
  // Customer slice
  ctx.beginPath(); ctx.moveTo(50,50);
  ctx.arc(50,50,46, -Math.PI/2 + staffAngle, -Math.PI/2 + 2*Math.PI);
  ctx.closePath(); ctx.fillStyle = '#63b3ed'; ctx.fill();
  // Staff slice
  ctx.beginPath(); ctx.moveTo(50,50);
  ctx.arc(50,50,46, -Math.PI/2, -Math.PI/2 + staffAngle);
  ctx.closePath(); ctx.fillStyle = '#68d391'; ctx.fill();

  const staffPct  = Math.round(d.staff_count / total * 100);
  const custPct   = 100 - staffPct;
  document.getElementById('pieLegend').innerHTML = `
    <div class="pie-legend-row"><div class="pie-dot" style="background:#68d391"></div>
      Staff — ${d.staff_count} turns (${staffPct}%)</div>
    <div class="pie-legend-row"><div class="pie-dot" style="background:#63b3ed"></div>
      Customer — ${d.customer_count} turns (${custPct}%)</div>
    <div style="font-size:0.75rem;color:#4a5568;margin-top:4px">
      Diarizer: ${d.diar_mode}</div>`;
}

function fmt(s) {
  const m = Math.floor(s / 60), sec = (s % 60).toFixed(1).padStart(4,'0');
  return m > 0 ? `${m}m${sec}s` : `${parseFloat(sec).toFixed(1)}s`;
}

// ── Real-time microphone ──────────────────────────────────────────────────────
let mediaRecorder   = null;
let audioChunks     = [];
let micStream       = null;
let audioCtx        = null;
let analyserNode    = null;
let waveAnimFrame   = null;
let recTimerInterval= null;
let recSeconds      = 0;
let micBlob         = null;  // last completed recording

const micBtn        = document.getElementById('micBtn');
const micZone       = document.getElementById('micZone');
const micStatus     = document.getElementById('micStatus');
const recTimer      = document.getElementById('recTimer');
const waveCanvas    = document.getElementById('waveformCanvas');
const micAnalyseBtn = document.getElementById('micAnalyseBtn');
const micClearBtn   = document.getElementById('micClearBtn');
const micProgress   = document.getElementById('micProgress');
const micProgressFill = document.getElementById('micProgressFill');
const micProgressText = document.getElementById('micProgressText');
const micErrorBox   = document.getElementById('micErrorBox');

async function toggleMic() {
  if (mediaRecorder && mediaRecorder.state === 'recording') {
    stopRecording();
  } else {
    await startRecording();
  }
}

async function startRecording() {
  micErrorBox.style.display = 'none';
  micBlob = null;
  micAnalyseBtn.style.display = 'none';
  micClearBtn.style.display   = 'none';
  document.getElementById('micResults').style.display = 'none';

  try {
    micStream = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
  } catch (err) {
    setMicStatus('Microphone access denied: ' + err.message, 'error');
    return;
  }

  // Waveform visualiser
  audioCtx    = new (window.AudioContext || window.webkitAudioContext)();
  analyserNode= audioCtx.createAnalyser();
  analyserNode.fftSize = 256;
  audioCtx.createMediaStreamSource(micStream).connect(analyserNode);
  waveCanvas.style.display = 'block';
  drawWaveform();

  // MediaRecorder — prefer webm/opus, fall back to whatever is available
  const mimeType = MediaRecorder.isTypeSupported('audio/webm;codecs=opus')
                     ? 'audio/webm;codecs=opus'
                     : MediaRecorder.isTypeSupported('audio/ogg;codecs=opus')
                       ? 'audio/ogg;codecs=opus' : '';
  const opts = mimeType ? { mimeType } : {};
  mediaRecorder = new MediaRecorder(micStream, opts);
  audioChunks   = [];

  mediaRecorder.ondataavailable = e => { if (e.data.size > 0) audioChunks.push(e.data); };
  mediaRecorder.onstop = () => finishRecording(mimeType || 'audio/webm');

  mediaRecorder.start(250);  // collect in 250ms chunks

  // UI
  micBtn.className   = 'mic-btn active';
  micBtn.textContent = '⏹';
  micZone.classList.add('recording');
  setMicStatus('<span class="live-dot"></span>Recording… click to stop', 'live');
  recSeconds = 0;
  recTimer.style.display = 'block';
  recTimerInterval = setInterval(() => {
    recSeconds++;
    const m = Math.floor(recSeconds / 60), s = String(recSeconds % 60).padStart(2,'0');
    recTimer.textContent = `${m}:${s}`;
  }, 1000);
}

function stopRecording() {
  if (mediaRecorder && mediaRecorder.state === 'recording') {
    mediaRecorder.stop();
  }
  if (micStream) { micStream.getTracks().forEach(t => t.stop()); micStream = null; }
  clearInterval(recTimerInterval);
  cancelAnimationFrame(waveAnimFrame);
  if (audioCtx) { audioCtx.close(); audioCtx = null; }
  waveCanvas.style.display = 'none';

  micBtn.className   = 'mic-btn processing';
  micBtn.textContent = '⏳';
  micZone.classList.remove('recording');
  setMicStatus('Finalising recording…', '');
}

function finishRecording(mimeType) {
  const ext  = mimeType.includes('ogg') ? 'ogg' : 'webm';
  micBlob    = new Blob(audioChunks, { type: mimeType });

  const durText = (() => {
    const m = Math.floor(recSeconds / 60), s = String(recSeconds % 60).padStart(2,'0');
    return `${m}:${s}`;
  })();

  micBtn.className   = 'mic-btn idle';
  micBtn.textContent = '🎤';
  recTimer.style.display = 'none';

  if (micBlob.size < 2000) {
    setMicStatus('Recording too short — please speak for at least 1 second.', 'error');
    micBlob = null;
    return;
  }

  setMicStatus(`✔ Recording ready (${durText}, ${(micBlob.size/1024).toFixed(0)} KB) — click Analyse or re-record`, 'ok');
  micAnalyseBtn.style.display = 'inline-block';
  micClearBtn.style.display   = 'inline-block';
}

function clearMicRecording() {
  micBlob = null;
  micAnalyseBtn.style.display = 'none';
  micClearBtn.style.display   = 'none';
  recTimer.style.display      = 'none';
  micErrorBox.style.display   = 'none';
  document.getElementById('micResults').style.display = 'none';
  setMicStatus('Click the microphone to start recording', '');
}

async function submitMicRecording() {
  if (!micBlob) return;

  micAnalyseBtn.disabled = true;
  micClearBtn.disabled   = true;
  micErrorBox.style.display = 'none';
  document.getElementById('micResults').style.display = 'none';
  micProgress.style.display = 'block';

  const steps = [
    [10, 'Loading audio…'],
    [25, 'Estimating speaker count…'],
    [40, 'Running neural diarization (pyannote)…'],
    [70, 'Computing voice embeddings (ECAPA-TDNN)…'],
    [85, 'Matching against staff database…'],
    [95, 'Building results…'],
  ];
  let si = 0;
  const ticker = setInterval(() => {
    if (si < steps.length) {
      micProgressFill.style.width = steps[si][0] + '%';
      micProgressText.textContent = steps[si][1];
      si++;
    }
  }, 1800);

  const fd = new FormData();
  fd.append('audio', micBlob, 'recording.webm');
  fd.append('threshold', document.getElementById('threshold').value);
  fd.append('max_duration', document.getElementById('maxDur').value);

  try {
    const resp = await fetch('/analyse_realtime', { method: 'POST', body: fd });
    clearInterval(ticker);
    micProgressFill.style.width = '100%';
    micProgressText.textContent = 'Done!';
    setTimeout(() => { micProgress.style.display = 'none'; }, 500);

    const data = await resp.json();
    if (data.error) {
      micErrorBox.textContent = '✗ ' + data.error;
      micErrorBox.style.display = 'block';
    } else {
      renderMicResults(data);
    }
  } catch (err) {
    clearInterval(ticker);
    micProgress.style.display = 'none';
    micErrorBox.textContent = '✗ Request failed: ' + err.message;
    micErrorBox.style.display = 'block';
  }

  micAnalyseBtn.disabled = false;
  micClearBtn.disabled   = false;
}

function renderMicResults(d) {
  const box = document.getElementById('micResults');
  box.style.display = 'block';

  // Stats
  const total   = d.staff_count + d.customer_count;
  const trimNote= d.total_duration > d.duration
    ? ` <span style="font-size:0.7rem;color:#718096">of ${fmt(d.total_duration)}</span>` : '';
  document.getElementById('micStatsGrid').innerHTML = `
    <div class="stat"><div class="val">${fmt(d.duration)}${trimNote}</div><div class="lbl">Processed</div></div>
    <div class="stat blue"><div class="val">${d.segments.length}</div><div class="lbl">Segments</div></div>
    <div class="stat green"><div class="val">${d.staff_count}</div><div class="lbl">Staff turns</div></div>
    <div class="stat amber"><div class="val">${d.customer_count}</div><div class="lbl">Customer turns</div></div>
    <div class="stat"><div class="val">${d.est_speakers}</div><div class="lbl">Speakers est.</div></div>
    <div class="stat"><div class="val">${d.elapsed}s</div><div class="lbl">Processing time</div></div>
  `;

  // Timeline
  const dur = d.duration;
  const tl  = document.getElementById('micTimeline');
  tl.innerHTML = '';
  d.segments.forEach(s => {
    const left  = (s.start / dur * 100).toFixed(2);
    const width = Math.max((s.duration / dur * 100), 0.3).toFixed(2);
    const col   = d.speaker_colour[s.speaker_id] || '#4f8ef7';
    const alpha = s.role === 'staff' ? 'ff' : '99';
    const div   = document.createElement('div');
    div.className = 'timeline-seg';
    div.style.cssText = `left:${left}%;width:${width}%;background:${col}${alpha}`;
    div.title = `${s.speaker_id} · ${s.role}${s.name ? ' · '+s.name : ''} · ${fmt(s.start)}–${fmt(s.end)}`;
    if (parseFloat(width) > 3) div.innerHTML = `<span class="seg-label">${s.name||s.speaker_id}</span>`;
    tl.appendChild(div);
  });
  const ticks = document.getElementById('micTimelineTicks');
  ticks.innerHTML = '';
  for (let i = 0; i <= 6; i++) {
    const sp = document.createElement('span');
    sp.textContent = fmt(dur * i / 6);
    ticks.appendChild(sp);
  }
  document.getElementById('micLegend').innerHTML =
    Object.entries(d.speaker_colour).map(([spk, col]) =>
      `<div class="legend-item"><div class="legend-dot" style="background:${col}"></div>${spk}</div>`
    ).join('');

  // Speaking time bars
  const maxT = Math.max(...Object.values(d.speaker_totals), 1);
  document.getElementById('micSpeakerBars').innerHTML =
    Object.entries(d.speaker_totals).sort((a,b)=>b[1]-a[1]).map(([spk, t]) => `
      <div class="speaker-row">
        <div class="speaker-name">${spk}</div>
        <div class="speaker-bar-bg">
          <div class="speaker-bar-fill"
               style="width:${t/maxT*100}%;background:${d.speaker_colour[spk]||'#4f8ef7'}">
            ${t.toFixed(1)}s
          </div>
        </div>
      </div>`).join('');

  // Pie
  const canvas2 = document.getElementById('micPieChart');
  const ctx2    = canvas2.getContext('2d');
  const tot2    = (d.staff_count + d.customer_count) || 1;
  const staffA  = (d.staff_count / tot2) * 2 * Math.PI;
  ctx2.clearRect(0,0,100,100);
  ctx2.beginPath(); ctx2.moveTo(50,50); ctx2.arc(50,50,46,-Math.PI/2+staffA,-Math.PI/2+2*Math.PI);
  ctx2.closePath(); ctx2.fillStyle='#63b3ed'; ctx2.fill();
  ctx2.beginPath(); ctx2.moveTo(50,50); ctx2.arc(50,50,46,-Math.PI/2,-Math.PI/2+staffA);
  ctx2.closePath(); ctx2.fillStyle='#68d391'; ctx2.fill();
  document.getElementById('micPieLegend').innerHTML = `
    <div class="pie-legend-row"><div class="pie-dot" style="background:#68d391"></div>
      Staff — ${d.staff_count} turns (${Math.round(d.staff_count/tot2*100)}%)</div>
    <div class="pie-legend-row"><div class="pie-dot" style="background:#63b3ed"></div>
      Customer — ${d.customer_count} turns (${Math.round(d.customer_count/tot2*100)}%)</div>`;

  // Table
  document.getElementById('micSegTable').innerHTML = d.segments.map(s => `
    <tr>
      <td>${fmt(s.start)}</td><td>${fmt(s.end)}</td><td>${s.duration.toFixed(1)}s</td>
      <td><span style="color:${d.speaker_colour[s.speaker_id]||'#fff'}">${s.speaker_id}</span></td>
      <td><span class="role-${s.role}">${s.role.toUpperCase()}</span></td>
      <td>${s.name||'<span style="color:#4a5568">—</span>'}</td>
      <td>
        <div class="score-bar">
          <div class="score-fill" style="width:${Math.round(s.score*80)}px;
               background:${s.score>=d.threshold?'#68d391':'#4f8ef7'}"></div>
          <span style="font-size:0.8rem;color:#a0aec0">${s.score.toFixed(3)}</span>
        </div>
      </td>
    </tr>`).join('');

  box.scrollIntoView({ behavior: 'smooth' });
}

function setMicStatus(html, cls) {
  micStatus.innerHTML  = html;
  micStatus.className  = 'mic-status' + (cls ? ' ' + cls : '');
}

function drawWaveform() {
  if (!analyserNode) return;
  waveAnimFrame = requestAnimationFrame(drawWaveform);
  const buf  = new Uint8Array(analyserNode.frequencyBinCount);
  analyserNode.getByteTimeDomainData(buf);
  const ctx  = waveCanvas.getContext('2d');
  const W    = waveCanvas.offsetWidth || 400;
  const H    = waveCanvas.offsetHeight || 48;
  waveCanvas.width  = W;
  waveCanvas.height = H;
  ctx.clearRect(0, 0, W, H);
  ctx.strokeStyle = '#4f8ef7';
  ctx.lineWidth   = 1.5;
  ctx.beginPath();
  const sliceW = W / buf.length;
  let x = 0;
  for (let i = 0; i < buf.length; i++) {
    const y = (buf[i] / 128) * (H / 2);
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    x += sliceW;
  }
  ctx.stroke();
}
</script>
</body>
</html>
